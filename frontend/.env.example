# ────────────────────────────────────────────────────────────────────────────────
# Firma Solar — Observabilidade (Prometheus + Grafana)
# Copie este arquivo para .env e preencha os valores antes de iniciar.
# O arquivo .env NUNCA deve ser versionado no git.
# ────────────────────────────────────────────────────────────────────────────────


# ── Grafana ───────────────────────────────────────────────────────────────────
# Usuário admin do Grafana (padrão: admin)
GF_ADMIN_USER=admin

# Senha do usuário admin — use uma senha forte em produção
GF_ADMIN_PASSWORD=


# ── Prometheus ────────────────────────────────────────────────────────────────
# O Prometheus usa um arquivo de token para autenticar no backend Django.
# Crie o arquivo prometheus/metrics_token.txt com o mesmo valor de
# METRICAS_TOKEN definido no .env do backend_monitoramento.
# Esse arquivo também deve estar no .gitignore.
