# ────────────────────────────────────────────────────────────────────────────────
# Firma Solar — Observabilidade (Grafana)
# Copie este arquivo para .env e preencha os valores antes de iniciar.
# O arquivo .env NUNCA deve ser versionado no git.
# ────────────────────────────────────────────────────────────────────────────────


# ── Grafana ───────────────────────────────────────────────────────────────────
# Usuário admin do Grafana (padrão: admin)
GF_ADMIN_USER=admin

# Senha do usuário admin — use uma senha forte em produção
GF_ADMIN_PASSWORD=


# ── PostgreSQL (datasource do Grafana) ────────────────────────────────────────
# Mesmo banco usado pelo backend_monitoramento.
# O Grafana acessa via host.docker.internal (PostgreSQL exposto em 127.0.0.1:5432).
DB_NOME=firmasolar
DB_USUARIO=firmasolar
DB_SENHA=
