{
  "title": "Usinas Afetadas",
  "uid": "usinas-afetadas",
  "schemaVersion": 38,
  "version": 1,
  "timezone": "America/Sao_Paulo",
  "refresh": "1m",
  "time": { "from": "now-7d", "to": "now" },
  "tags": ["alertas", "solar", "detalhe"],
  "panels": [
    {
      "id": 1,
      "title": "Usinas com Alertas Abertos",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "valueSize": 48 }
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green",  "value": 0 },
              { "color": "orange", "value": 1 }
            ]
          },
          "links": [
            {
              "title": "Voltar ao monitoramento",
              "url": "/d/alertas-monitoramento/monitoramento-de-alertas",
              "targetBlank": false
            }
          ]
        }
      },
      "targets": [
        {
          "datasource": { "uid": "postgres-firmasolar" },
          "rawSql": "SELECT COUNT(DISTINCT a.usina_id)::int FROM alertas_alerta a JOIN usinas_usina u ON u.id = a.usina_id WHERE a.estado = 'ativo' AND u.ativo = true",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Resumo por Usina",
      "type": "table",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 20 },
      "options": {
        "cellHeight": "sm",
        "footer": { "show": false },
        "sortBy": [
          { "displayName": "Pior Nível", "desc": false }
        ]
      },
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Usina" },
            "properties": [
              { "id": "custom.width", "value": 240 },
              {
                "id": "links",
                "value": [
                  {
                    "title": "Ver detalhe da usina",
                    "url": "/d/detalhe-usina/detalhe-da-usina?var-usina=${__value.text}",
                    "targetBlank": true
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Pior Nível" },
            "properties": [
              { "id": "custom.width", "value": 130 },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "critico":    { "text": "CRÍTICO",    "color": "dark-red", "index": 0 } } },
                  { "type": "value", "options": { "importante": { "text": "IMPORTANTE", "color": "orange",  "index": 1 } } },
                  { "type": "value", "options": { "aviso":      { "text": "AVISO",      "color": "yellow",  "index": 2 } } },
                  { "type": "value", "options": { "info":       { "text": "INFO",       "color": "green",   "index": 3 } } }
                ]
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Críticos" },
            "properties": [
              { "id": "custom.width", "value": 90 },
              { "id": "color", "value": { "mode": "thresholds" } },
              {
                "id": "thresholds",
                "value": {
                  "steps": [
                    { "color": "green", "value": 0 },
                    { "color": "red",   "value": 1 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-text" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Importantes" },
            "properties": [
              { "id": "custom.width", "value": 110 },
              { "id": "color", "value": { "mode": "thresholds" } },
              {
                "id": "thresholds",
                "value": {
                  "steps": [
                    { "color": "text",   "value": 0 },
                    { "color": "orange", "value": 1 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-text" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Avisos" },
            "properties": [
              { "id": "custom.width", "value": 90 },
              { "id": "color", "value": { "mode": "thresholds" } },
              {
                "id": "thresholds",
                "value": {
                  "steps": [
                    { "color": "text",   "value": 0 },
                    { "color": "yellow", "value": 1 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-text" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Total Alertas" },
            "properties": [
              { "id": "custom.width", "value": 110 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Desde" },
            "properties": [
              { "id": "custom.width", "value": 160 },
              { "id": "unit", "value": "time:DD/MM/YYYY HH:mm" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Tempo mais antigo" },
            "properties": [
              { "id": "custom.width", "value": 140 },
              { "id": "unit", "value": "dtdurations" },
              { "id": "decimals", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Provedor" },
            "properties": [
              { "id": "custom.width", "value": 110 }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "uid": "postgres-firmasolar" },
          "rawSql": "SELECT u.nome AS \"Usina\", INITCAP(u.provedor) AS \"Provedor\", CASE MAX(CASE a.nivel WHEN 'critico' THEN 4 WHEN 'importante' THEN 3 WHEN 'aviso' THEN 2 ELSE 1 END) WHEN 4 THEN 'critico' WHEN 3 THEN 'importante' WHEN 2 THEN 'aviso' ELSE 'info' END AS \"Pior Nível\", COUNT(a.id)::int AS \"Total Alertas\", COUNT(CASE WHEN a.nivel = 'critico' THEN 1 END)::int AS \"Críticos\", COUNT(CASE WHEN a.nivel = 'importante' THEN 1 END)::int AS \"Importantes\", COUNT(CASE WHEN a.nivel = 'aviso' THEN 1 END)::int AS \"Avisos\", MIN(a.inicio) AS \"Desde\", EXTRACT(EPOCH FROM (NOW() - MIN(a.inicio)))::bigint AS \"Tempo mais antigo\" FROM alertas_alerta a JOIN usinas_usina u ON a.usina_id = u.id WHERE a.estado = 'ativo' AND u.ativo = true GROUP BY u.id, u.nome, u.provedor ORDER BY MAX(CASE a.nivel WHEN 'critico' THEN 4 WHEN 'importante' THEN 3 WHEN 'aviso' THEN 2 ELSE 1 END) DESC, COUNT(a.id) DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ]
}
