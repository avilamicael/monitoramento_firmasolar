{
  "title": "Firma Solar — Painel de Suporte Técnico",
  "uid": "firma-solar-suporte",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [

    {
      "id": 1,
      "title": "🔴 Usinas Offline",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "valueSize": 48 }
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "count(solar_usina_status == 2) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "title": "⚠️ Usinas com Alertas",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "valueSize": 48 }
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "count(solar_usina_qtd_alertas > 0) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "title": "🔗 Providers sem Coleta (> 20 min)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "valueSize": 48 }
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "count((time() - solar_ultima_coleta_timestamp) > 1200) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "title": "🔑 Credenciais com Erro de Auth",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "valueSize": 48 }
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "sum(solar_credencial_precisa_atencao) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "title": "⚡ Potência Total",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "kwatt",
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 10 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "sum(solar_usina_potencia_kw)",
          "refId": "A"
        }
      ]
    },

    {
      "id": 6,
      "title": "☀️ Energia Hoje",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "noValue": "0",
          "decimals": 1,
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "sum(solar_usina_energia_hoje_kwh) / 1000",
          "legendFormat": "MWh",
          "refId": "A"
        }
      ]
    },

    {
      "id": 20,
      "title": "🔴 Problemas Ativos — Alertas Críticos",
      "type": "table",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "options": {
        "sortBy": [{ "displayName": "Usina", "desc": false }],
        "cellHeight": "sm",
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left" },
          "noValue": "—"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "Time" }, "properties": [{ "id": "custom.hidden", "value": true }] },
          {
            "matcher": { "id": "byName", "options": "nome_usina" },
            "properties": [
              { "id": "displayName", "value": "Usina" },
              { "id": "custom.width", "value": 220 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "provedor" },
            "properties": [
              { "id": "displayName", "value": "Provider" },
              { "id": "custom.width", "value": 110 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "mensagem" },
            "properties": [
              { "id": "displayName", "value": "Descrição do Problema" },
              { "id": "custom.width", "value": 420 }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "solar_usina_alerta_ativo{nivel=\"critico\"} == 1",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        {
          "id": "organize",
          "options": {
            "includeByName": {
              "nome_usina": true,
              "provedor": true,
              "mensagem": true
            },
            "excludeByName": { "Time": true, "Value": true, "id_usina": true, "nivel": true }
          }
        }
      ]
    },

    {
      "id": 21,
      "title": "Status de Coleta por Provider",
      "type": "table",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 7 },
      "options": {
        "sortBy": [{ "displayName": "Minutos desde última coleta", "desc": true }],
        "cellHeight": "sm",
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "provedor" },
            "properties": [
              { "id": "displayName", "value": "Provider" },
              { "id": "custom.width", "value": 130 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #A" },
            "properties": [
              { "id": "displayName", "value": "Minutos desde última coleta" },
              { "id": "unit", "value": "m" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.width", "value": 200 },
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "color", "value": { "mode": "thresholds" } },
              {
                "id": "thresholds",
                "value": {
                  "steps": [
                    { "color": "green", "value": 0 },
                    { "color": "yellow", "value": 15 },
                    { "color": "orange", "value": 30 },
                    { "color": "red", "value": 60 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #B" },
            "properties": [
              { "id": "displayName", "value": "Credencial com problema" },
              { "id": "custom.width", "value": 170 },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "text": "✅ OK", "color": "green", "index": 0 } } },
                  { "type": "range", "options": { "from": 1, "to": 999, "result": { "text": "🔴 Verificar credencial", "color": "red" } } }
                ]
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "(time() - solar_ultima_coleta_timestamp) / 60",
          "instant": true,
          "format": "table",
          "legendFormat": "",
          "refId": "A"
        },
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "solar_credencial_precisa_atencao",
          "instant": true,
          "format": "table",
          "legendFormat": "",
          "refId": "B"
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true }
          }
        }
      ]
    },

    {
      "id": 22,
      "title": "Erros de Coleta nas Últimas 24h",
      "type": "table",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 7 },
      "options": {
        "sortBy": [{ "displayName": "Erros", "desc": true }],
        "cellHeight": "sm",
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "provedor" },
            "properties": [
              { "id": "displayName", "value": "Provider" },
              { "id": "custom.width", "value": 130 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #A" },
            "properties": [
              { "id": "displayName", "value": "Sucesso 24h" },
              { "id": "custom.width", "value": 110 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #B" },
            "properties": [
              { "id": "displayName", "value": "Erros 24h" },
              { "id": "custom.width", "value": 90 },
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "color", "value": { "mode": "thresholds" } },
              {
                "id": "thresholds",
                "value": {
                  "steps": [
                    { "color": "green", "value": 0 },
                    { "color": "orange", "value": 1 },
                    { "color": "red", "value": 3 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #C" },
            "properties": [
              { "id": "displayName", "value": "Erro de Auth" },
              { "id": "custom.width", "value": 110 },
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "color", "value": { "mode": "thresholds" } },
              {
                "id": "thresholds",
                "value": {
                  "steps": [
                    { "color": "green", "value": 0 },
                    { "color": "red", "value": 1 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "solar_coleta_24h_total{status=\"sucesso\"} or (label_replace(solar_ultima_coleta_timestamp * 0, \"status\", \"sucesso\", \"\", \"\"))",
          "instant": true,
          "format": "table",
          "legendFormat": "",
          "refId": "A"
        },
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "solar_coleta_24h_total{status=\"erro\"} or (label_replace(solar_ultima_coleta_timestamp * 0, \"status\", \"erro\", \"\", \"\"))",
          "instant": true,
          "format": "table",
          "legendFormat": "",
          "refId": "B"
        },
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "solar_coleta_24h_total{status=\"auth_erro\"} or (label_replace(solar_ultima_coleta_timestamp * 0, \"status\", \"auth_erro\", \"\", \"\"))",
          "instant": true,
          "format": "table",
          "legendFormat": "",
          "refId": "C"
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "status": true }
          }
        }
      ]
    },

    {
      "id": 30,
      "title": "Histórico — Status da Frota (últimas 24h)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 19, "w": 24, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "min": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Offline" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Com alerta" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Potência (kW)" },
            "properties": [
              { "id": "unit", "value": "kwatt" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "count(solar_usina_status == 2) or vector(0)",
          "legendFormat": "Offline",
          "refId": "A"
        },
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "count(solar_usina_qtd_alertas > 0) or vector(0)",
          "legendFormat": "Com alerta",
          "refId": "B"
        },
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "sum(solar_usina_potencia_kw)",
          "legendFormat": "Potência (kW)",
          "refId": "C"
        }
      ]
    }

  ]
}
