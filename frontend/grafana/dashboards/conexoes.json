{
  "title": "Firma Solar — Conexões com Provedores",
  "uid": "firma-solar-conexoes",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [

    {
      "id": 1,
      "title": "✅ Providers com Coleta Recente (< 20 min)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "valueSize": 40 }
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "count((time() - solar_ultima_coleta_timestamp) < 1200) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "title": "🔴 Providers com Credencial com Problema",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "valueSize": 40 }
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "count(solar_credencial_precisa_atencao > 0) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "title": "📊 Coletas com Sucesso nas Últimas 24h",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "valueSize": 40 }
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 10 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "sum(solar_coleta_24h_total{status=\"sucesso\"}) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "title": "❌ Coletas com Erro nas Últimas 24h",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "valueSize": 40 }
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "sum(solar_coleta_24h_total{status=~\"erro|auth_erro\"}) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 10,
      "title": "Status de Conexão por Provider",
      "type": "table",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "options": {
        "sortBy": [{ "displayName": "Minutos desde última coleta", "desc": true }],
        "footer": { "show": false },
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #A" },
            "properties": [
              { "id": "displayName", "value": "Minutos desde última coleta" },
              { "id": "unit", "value": "m" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.width", "value": 200 },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "color",
                "value": { "mode": "thresholds" }
              },
              {
                "id": "thresholds",
                "value": {
                  "steps": [
                    { "color": "green", "value": 0 },
                    { "color": "yellow", "value": 15 },
                    { "color": "orange", "value": 30 },
                    { "color": "red", "value": 60 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #B" },
            "properties": [
              { "id": "displayName", "value": "Sucesso 24h" },
              { "id": "custom.width", "value": 110 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #C" },
            "properties": [
              { "id": "displayName", "value": "Erro 24h" },
              { "id": "custom.width", "value": 90 },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "color",
                "value": { "mode": "thresholds" }
              },
              {
                "id": "thresholds",
                "value": {
                  "steps": [
                    { "color": "green", "value": 0 },
                    { "color": "orange", "value": 1 },
                    { "color": "red", "value": 3 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #D" },
            "properties": [
              { "id": "displayName", "value": "Precisa atenção" },
              { "id": "custom.width", "value": 130 },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "text": "✅ OK", "color": "green", "index": 0 } } },
                  { "type": "range", "options": { "from": 1, "to": 999, "result": { "text": "🔴 Com erro", "color": "red" } } }
                ]
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "provedor" },
            "properties": [
              { "id": "displayName", "value": "Provider" },
              { "id": "custom.width", "value": 130 }
            ]
          }
        ]
      },
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true }
          }
        }
      ],
      "targets": [
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "(time() - solar_ultima_coleta_timestamp) / 60",
          "instant": true,
          "format": "table",
          "legendFormat": "",
          "refId": "A"
        },
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "solar_coleta_24h_total{status=\"sucesso\"} or (label_replace(solar_ultima_coleta_timestamp * 0, \"status\", \"sucesso\", \"\", \"\"))",
          "instant": true,
          "format": "table",
          "legendFormat": "",
          "refId": "B"
        },
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "sum by (provedor) (solar_coleta_24h_total{status=~\"erro|auth_erro\"}) or (label_replace(solar_ultima_coleta_timestamp * 0, \"status\", \"erro\", \"\", \"\"))",
          "instant": true,
          "format": "table",
          "legendFormat": "",
          "refId": "C"
        },
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "solar_credencial_precisa_atencao",
          "instant": true,
          "format": "table",
          "legendFormat": "",
          "refId": "D"
        }
      ]
    },

    {
      "id": 20,
      "title": "Tempo desde Última Coleta por Provider (minutos)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 16, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "m",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 15 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "(time() - solar_ultima_coleta_timestamp) / 60",
          "legendFormat": "{{provedor}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 21,
      "title": "Taxa de Sucesso 24h por Provider (%)",
      "type": "bargauge",
      "gridPos": { "x": 16, "y": 12, "w": 8, "h": 8 },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient",
        "showUnfilled": true,
        "min": 0,
        "max": 100
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "orange", "value": 50 },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "100 * solar_coleta_24h_total{status=\"sucesso\"} / clamp_min(sum by (provedor) (solar_coleta_24h_total), 1)",
          "legendFormat": "{{provedor}}",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 30,
      "title": "Coletas com Sucesso ao Longo do Tempo",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 7 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "min": 0
        }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "solar_coleta_24h_total{status=\"sucesso\"}",
          "legendFormat": "{{provedor}} — sucesso",
          "refId": "A"
        }
      ]
    },

    {
      "id": 31,
      "title": "Coletas com Erro ao Longo do Tempo",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 7 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "min": 0
        }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "solar_coleta_24h_total{status=\"erro\"}",
          "legendFormat": "{{provedor}} — erro",
          "refId": "A"
        },
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "solar_coleta_24h_total{status=\"auth_erro\"}",
          "legendFormat": "{{provedor}} — auth_erro",
          "refId": "B"
        },
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "solar_coleta_24h_total{status=\"parcial\"}",
          "legendFormat": "{{provedor}} — parcial",
          "refId": "C"
        }
      ]
    }

  ]
}
