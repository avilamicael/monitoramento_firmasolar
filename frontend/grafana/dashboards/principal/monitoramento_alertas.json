      "targets": [
        {
          "datasource": { "uid": "postgres-firmasolar" },
          "rawSql": "SELECT COUNT(*)::int FROM alertas_alerta a JOIN usinas_usina u ON u.id = a.usina_id WHERE a.estado = 'ativo' AND u.ativo = true AND a.nivel = 'importante'",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Avisos Ativos",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "valueSize": 48 }
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 }
            ]
          },
          "links": [
            {
              "title": "Ver alertas de aviso",
              "url": "/d/lista-alertas/lista-de-alertas?var-filtro=aviso",
