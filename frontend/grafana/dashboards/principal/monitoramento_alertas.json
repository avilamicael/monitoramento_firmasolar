          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          },
          "links": [
            {
              "title": "Ver alertas críticos",
              "url": "/d/lista-alertas/lista-de-alertas?var-filtro=critico",
              "targetBlank": false
            }
          ]
        }
      },
      "targets": [
        {
          "datasource": { "uid": "postgres-firmasolar" },
          "rawSql": "SELECT COUNT(*)::int FROM alertas_alerta a JOIN usinas_usina u ON u.id = a.usina_id WHERE a.estado = 'ativo' AND u.ativo = true AND a.nivel = 'critico'",
          "format": "table",
          "refId": "A"
