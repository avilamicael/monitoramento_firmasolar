{
  "title": "Monitoramento de Alertas",
  "uid": "alertas-monitoramento",
  "schemaVersion": 38,
  "version": 2,
  "timezone": "America/Sao_Paulo",
  "refresh": "5m",
  "time": { "from": "now-7d", "to": "now" },
  "tags": ["alertas", "solar"],
  "panels": [
    {
      "id": 1,
      "title": "Alertas Abertos",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "valueSize": 48 }
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          },
          "links": [
            {
              "title": "Ver lista de alertas abertos",
              "url": "/d/lista-alertas/lista-de-alertas?var-filtro=abertos",
              "targetBlank": false
            }
          ]
        }
      },
      "targets": [
        {
          "datasource": { "uid": "postgres-firmasolar" },
          "rawSql": "SELECT COUNT(*)::int FROM alertas_alerta a JOIN usinas_usina u ON u.id = a.usina_id WHERE a.estado = 'ativo' AND u.ativo = true",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Críticos Ativos",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
