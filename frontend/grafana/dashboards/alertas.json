{
  "title": "Firma Solar — Alertas e Problemas",
  "uid": "firma-solar-alertas",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [

    {
      "id": 1,
      "title": "🔴 Alertas Críticos Ativos",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "valueSize": 48 }
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "count(solar_usina_alerta_ativo{nivel=\"critico\"}) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "title": "⚠️ Alertas de Aviso Ativos",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "valueSize": 48 }
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "count(solar_usina_alerta_ativo{nivel=\"aviso\"}) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "title": "Usinas com Algum Alerta",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "valueSize": 48 }
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "orange", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "count(count by (id_usina) (solar_usina_alerta_ativo)) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "title": "Total de Alertas por Provider",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 8 },
      "options": {
        "displayLabels": ["name", "value"],
        "legend": { "displayMode": "table", "placement": "right", "values": ["value"] }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "count by (provedor) (solar_usina_alerta_ativo)",
          "instant": true,
          "legendFormat": "{{provedor}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "title": "Alertas por Nível",
      "type": "piechart",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 8 },
      "options": {
        "displayLabels": ["name", "value"],
        "legend": { "displayMode": "table", "placement": "right", "values": ["value"] }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "critico" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "aviso" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "count by (nivel) (solar_usina_alerta_ativo)",
          "instant": true,
          "legendFormat": "{{nivel}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 10,
      "title": "🔴 Alertas CRÍTICOS — Detalhes",
      "type": "table",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 10 },
      "options": {
        "sortBy": [{ "displayName": "Usina", "desc": false }],
        "cellHeight": "sm",
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "left" },
          "noValue": "—"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          },
          {
            "matcher": { "id": "byName", "options": "nome_usina" },
            "properties": [
              { "id": "displayName", "value": "Usina" },
              { "id": "custom.width", "value": 200 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "provedor" },
            "properties": [
              { "id": "displayName", "value": "Provider" },
              { "id": "custom.width", "value": 100 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "mensagem" },
            "properties": [
              { "id": "displayName", "value": "Problema" },
              { "id": "custom.width", "value": 400 }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "solar_usina_alerta_ativo{nivel=\"critico\"} == 1",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        {
          "id": "organize",
          "options": {
            "includeByName": {
              "nome_usina": true,
              "provedor": true,
              "mensagem": true
            },
            "excludeByName": {
              "Time": true,
              "Value": true,
              "id_usina": true,
              "nivel": true
            }
          }
        }
      ]
    },

    {
      "id": 11,
      "title": "⚠️ Alertas de AVISO — Detalhes",
      "type": "table",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 10 },
      "options": {
        "sortBy": [{ "displayName": "Usina", "desc": false }],
        "cellHeight": "sm",
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "left" },
          "noValue": "—"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          },
          {
            "matcher": { "id": "byName", "options": "nome_usina" },
            "properties": [
              { "id": "displayName", "value": "Usina" },
              { "id": "custom.width", "value": 200 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "provedor" },
            "properties": [
              { "id": "displayName", "value": "Provider" },
              { "id": "custom.width", "value": 100 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "mensagem" },
            "properties": [
              { "id": "displayName", "value": "Problema" },
              { "id": "custom.width", "value": 400 }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "solar_usina_alerta_ativo{nivel=\"aviso\"} == 1",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        {
          "id": "organize",
          "options": {
            "includeByName": {
              "nome_usina": true,
              "provedor": true,
              "mensagem": true
            },
            "excludeByName": {
              "Time": true,
              "Value": true,
              "id_usina": true,
              "nivel": true
            }
          }
        }
      ]
    },

    {
      "id": 20,
      "title": "Histórico — Alertas Ativos ao Longo do Tempo",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 8 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "min": 0
        }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "count(solar_usina_alerta_ativo{nivel=\"critico\"}) or vector(0)",
          "legendFormat": "Críticos",
          "refId": "A"
        },
        {
          "datasource": { "uid": "prometheus-firmasolar" },
          "expr": "count(solar_usina_alerta_ativo{nivel=\"aviso\"}) or vector(0)",
          "legendFormat": "Avisos",
          "refId": "B"
        }
      ]
    }

  ],

  "templating": {
    "list": [
      {
        "name": "provedor",
        "type": "query",
        "label": "Provider",
        "datasource": { "uid": "prometheus-firmasolar" },
        "query": "label_values(solar_usina_alerta_ativo, provedor)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "hide": 0
      }
    ]
  }
}
