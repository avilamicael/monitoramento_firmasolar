# ────────────────────────────────────────────────────────────────────────────────
# Firma Solar — Backend de Monitoramento
# Copie este arquivo para .env e preencha os valores antes de iniciar o sistema.
# O arquivo .env NUNCA deve ser versionado no git.
# ────────────────────────────────────────────────────────────────────────────────


# ── Django ────────────────────────────────────────────────────────────────────
# Gerar: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# 'true' em desenvolvimento, 'false' em produção
DEBUG=false

# Hosts permitidos (separados por vírgula)
# Desenvolvimento: localhost,127.0.0.1
# Produção: monitoramento.firmasolar.com.br
ALLOWED_HOSTS=localhost


# ── Banco de dados (PostgreSQL) ───────────────────────────────────────────────
DB_NOME=monitoramento
DB_USUARIO=solar
DB_SENHA=
DB_HOST=localhost
DB_PORTA=5432


# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0


# ── Criptografia das credenciais dos provedores ───────────────────────────────
# Gerar: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANTE: se perder esta chave, as credenciais salvas no banco se tornam ilegíveis.
CHAVE_CRIPTOGRAFIA=


# ── Notificações — E-mail ─────────────────────────────────────────────────────
# Credenciais do servidor SMTP. Os destinatários são configurados no admin do Django.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORTA=587
EMAIL_USUARIO=
EMAIL_SENHA=
NOTIFICACAO_EMAIL_DE=noreply@firmasolar.com.br


# ── Notificações — WhatsApp ───────────────────────────────────────────────────
# Escolha o provedor: 'meta' (Meta Cloud API) ou 'evolution' (self-hosted)
# Os destinatários são configurados no admin do Django.
WHATSAPP_PROVEDOR=meta

# Meta Cloud API:
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=

# Evolution API (self-hosted):
WHATSAPP_EVOLUTION_URL=http://localhost:8080
WHATSAPP_EVOLUTION_TOKEN=
WHATSAPP_EVOLUTION_INSTANCIA=firma-solar
